{
  "listen": "",
  "port": 443,
  "protocol": "trojan",
  "tag": "in-443-tcp",
  "settings": {
    "clients": [ ]
  },
  "sniffing": {
    "enabled": true,
    "destOverride": [
      "http",
      "tls",
      "quic",
      "fakedns"
    ]
  },
  "streamSettings": {
    "network": "xhttp",
    "xhttpSettings": {
      "path": "",
      "host": "YOURDOMAIN.CLIENT.INHERE",
      "mode": "auto",
      "xPaddingBytes": "100-1000",
      "xPaddingObfsMode": true,
      "xPaddingKey": "32HEX (use random generator)",
      "xPaddingHeader": "Cookie",
      "xPaddingPlacement": "cookie",
      "xPaddingMethod": "tokenish",
      "sessionIDPlacement": "cookie",
      "sessionIDKey": "32HEX (use random generator)",
      "sessionIDTable": "Base62",
      "sessionIDLength": "16-32",
      "seqPlacement": "query",
      "seqKey": "16HEX (use random generator)",
      "uplinkDataPlacement": "",
      "uplinkDataKey": "",
      "scMaxEachPostBytes": "1000000",
      "noSSEHeader": false,
      "scMaxBufferedPosts": 30,
      "scStreamUpServerSecs": "20-80",
      "serverMaxHeaderBytes": 0,
      "uplinkHTTPMethod": "PUT",
      "headers": { },
      "scMinPostsIntervalMs": "",
      "uplinkChunkSize": 0,
      "noGRPCHeader": false,
      "xmux": {
        "maxConcurrency": "16-32",
        "maxConnections": "16",
        "cMaxReuseTimes": 0,
        "hMaxRequestTimes": "600-900",
        "hMaxReusableSecs": "1800-3000",
        "hKeepAlivePeriod": 0
      },
      "enableXmux": true
    },
    "security": "tls",
    "tlsSettings": {
      "serverName": "YOURDOMAIN.CLIENT.INHERE",
      "minVersion": "1.1",
      "maxVersion": "1.3",
      "cipherSuites": "",
      "rejectUnknownSni": false,
      "disableSystemRoot": false,
      "enableSessionResumption": true,
      "certificates": [
        {
          "certificateFile": "/root/cert/YOURDOMAIN.SERVER.INHERE/fullchain.pem",
          "keyFile": "/root/cert/YOURDOMAIN.SERVER.INHERE/privkey.pem",
          "ocspStapling": 0,
          "oneTimeLoading": true,
          "usage": "encipherment",
          "buildChain": false,
          "useFile": true
        }
      ],
      "alpn": [
        "h3",
        "h2"
      ],
      "echServerKeys": "",
      "curvePreferences": [
        "X25519MLKEM768",
        "X25519",
        "P-256",
        "P-384",
        "P-521"
      ],
      "settings": {
        "fingerprint": "randomized",
        "echConfigList": "",
        "pinnedPeerCertSha256": [ ],
        "verifyPeerCertByName": ""
      }
    },
    "externalProxy": [ ],
    "finalmask": {
      "quicParams": {
        "congestion": "bbr",
        "debug": false,
        "maxIdleTimeout": 30,
        "keepAlivePeriod": 10,
        "disablePathMTUDiscovery": true,
        "maxIncomingStreams": 1024,
        "initStreamReceiveWindow": 8388608,
        "maxStreamReceiveWindow": 8388608,
        "initConnectionReceiveWindow": 20971520,
        "maxConnectionReceiveWindow": 20971520,
        "bbrProfile": "aggressive",
        "udpHop": {
          "ports": "20000-50000",
          "interval": "5-10"
        }
      }
    },
    "sockopt": {
      "tcpFastOpen": true,
      "tproxy": "tproxy",
      "penetrate": true,
      "tcpMaxSeg": 1500,
      "tcpKeepAliveInterval": 60,
      "tcpKeepAliveIdle": 60,
      "tcpUserTimeout": 10000,
      "tcpcongestion": "bbr",
      "trustedXForwardedFor": [
        "CF-Connecting-IP",
        "X-Real-IP",
        "True-Client-IP",
        "X-Client-IP"
      ]
    }
  }
}